# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000
APP_NAME=NestJS Boilerplate
APP_DESCRIPTION=NestJS Boilerplate backend API

# ============================================================
# MongoDB
# ============================================================
MONGO_INITDB_DATABASE=turtles
MONGODB_URI=mongodb://mongodb:27017/turtles
MONGODB_PORT=27017

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ============================================================
# Seq (Structured Logging)
# ============================================================
SEQ_SERVER_URL=http://seq:5341
SEQ_API_KEY=
SEQ_HTTP_PORT=8081
SEQ_INGEST_PORT=5341

# ============================================================
# Resend
# ============================================================
RESEND_API_KEY=
RESEND_FROM=noreply@xjectro.com

# ============================================================
# Auth
# ============================================================
AUTH_JWT_SECRET=your_jwt_secret_key
