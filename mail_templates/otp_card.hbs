<!-- Card-style template matching provided image. Variables: title, date, excerpt, readMoreUrl, logoUrl, code -->
<span style='display:none;max-height:0;overflow:hidden;'>{{title}} — {{excerpt}}</span>

<div
  style='background:#ffffff;padding:32px;font-family:Inter,system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;'
>
  <table
    role='presentation'
    cellpadding='0'
    cellspacing='0'
    border='0'
    align='center'
    style='max-width:520px;margin:0 auto;width:100%;'
  >
    <tr>
      <td style='padding:0 0 20px 0;text-align:center;'>
        <table
          role='presentation'
          cellpadding='0'
          cellspacing='0'
          border='0'
          width='100%'
          style='background:#f7f7f7;border-radius:18px;overflow:hidden;box-shadow:0 6px 20px rgba(2,6,23,0.12);'
        >
          <tr>
            <td align='center' style='padding:28px 0 16px 0;'>
              <table role='presentation' cellpadding='0' cellspacing='0' border='0'>
                <tr>
                  <td
                    align='center'
                    style='width:84px;height:84px;border-radius:50%;background:linear-gradient(180deg,#ff8a00,#ff5e00);box-shadow:0 6px 0 rgba(0,0,0,0.15);'
                  >
                    <table
                      role='presentation'
                      cellpadding='0'
                      cellspacing='0'
                      border='0'
                      width='84'
                      height='84'
                    >
                      <tr>
                        <td align='center' valign='middle'>
                          {{#if logoUrl}}
                            <img
                              src='{{logoUrl}}'
                              alt='logo'
                              width='46'
                              height='46'
                              style='display:block;border-radius:6px;margin:0 auto;'
                            />
                          {{else}}
                            <img
                              src='https://www.orqon.io/favicon.ico'
                              alt='logo'
                              width='46'
                              height='46'
                              style='display:block;border-radius:6px;margin:0 auto;'
                            />
                          {{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style='background:#fcfcfc;padding:20px 24px 18px;border-top:1px solid #e6e6e6;'>
              <table role='presentation' cellpadding='0' cellspacing='0' border='0' width='100%'>
                <tr>
                  <td align='center' style='padding:0 0 8px 0;'>
                    <h2
                      style='margin:0;font-size:20px;font-weight:700;color:#111827;line-height:1.2;'
                    >{{title}}</h2>
                  </td>
                </tr>
                <tr>
                  <td align='center' style='padding:0 0 12px 0;font-size:12px;color:#6b7280;'>
                    {{date}}
                  </td>
                </tr>
                <tr>
                  <td
                    align='center'
                    style='padding:0 0 16px 0;font-size:14px;color:#6b7280;line-height:1.45;'
                  >
                    {{excerpt}}
                  </td>
                </tr>
                {{#if code}}
                  <tr>
                    <td align='center' style='padding:0 0 16px 0;'>
                      <table
                        role='presentation'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                        style='background:#eef2ff;border-radius:8px;'
                      >
                        <tr>
                          <td
                            align='center'
                            style='padding:10px 18px;font-weight:700;font-size:20px;letter-spacing:6px;color:#111827;'
                          >
                            {{code}}
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                {{/if}}
                <tr>
                  <td align='center' style='padding:0;'>
                    <a
                      href='{{readMoreUrl}}'
                      style='display:inline-block;color:#f97316;text-decoration:none;font-weight:600;'
                    >Read more →</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
    <tr>
      <td style='text-align:center;padding-top:8px;font-size:12px;color:#6b7280;'>&nbsp;</td>
    </tr>
  </table>
</div>