# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000

# ============================================================
# MongoDB
# ============================================================
MONGO_INITDB_DATABASE=turtles
MONGODB_URI=mongodb://mongodb:27017/turtles
MONGODB_PORT=27017

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ============================================================
# Seq (Structured Logging)
# ============================================================
SEQ_SERVER_URL=http://seq:5341
SEQ_API_KEY=
SEQ_HTTP_PORT=8081
SEQ_INGEST_PORT=5341

# ============================================================
# Monitoring - Exporters
# ============================================================
REDIS_EXPORTER_PORT=9121
MONGODB_EXPORTER_PORT=9216

# ============================================================
# Prometheus
# ============================================================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=30

# ============================================================
# Grafana
# ============================================================
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_AUTH_ANON=false
GRAFANA_AUTH_ANON_ROLE=Admin
GRAFANA_SERVER_ROOT_URL=http://localhost:3001/

# ============================================================
# Test-only
# ============================================================
# E2E_USE_MEMORY_SERVER=false
